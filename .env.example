# ============================================
# CAU HINH - Moi Gioi BDS Vault
# Sao che file nay thanh .env va dien gia tri thuc te
# File .env da duoc ket hop vao .gitignore
# ============================================

# Playlist ID tren YouTube
# Vi du: https://www.youtube.com/playlist?list=PLxxxxxx
# Chi copy phan sau "list="
PLAYLIST_ID="PUT_YOUR_PLAYLIST_ID_HERE"

# API Key Google Cloud (YouTube Data API v3)
# Lay tai: https://console.cloud.google.com/
API_KEY="PUT_YOUR_API_KEY_HERE"

# Ten thu muc vault se duoc tao
VAULT_NAME="Moi_Gioi_BDS_Vault"
